# ============================================================================
# Team Praise Official - Environment Configuration
# Copy this file to .env and update the values for your environment.
# ============================================================================

# Application
APP_NAME="Team Praise Official"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://teampraise.mcitng.com
#APP_KEY=generate-a-64-character-random-key-here # generate random key using: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=base64:your_base64_encoded_key_here
APP_TIMEZONE=Africa/Lagos

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mcitngco_teampraise
DB_USERNAME=mcitngco_tpuser
DB_PASSWORD=master@2026
DB_CHARSET=utf8mb4

# Mail (PHPMailer via SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=officialteampraise@gmail.com
MAIL_PASSWORD=Oscarpapa@18
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@teampraise.org
MAIL_FROM_NAME="Team Praise Official"

# Upload settings
UPLOAD_MAX_MB=8
UPLOAD_ALLOWED_EXT=jpg,jpeg,png,webp,gif,mp4,mp3,pdf

# Session
SESSION_LIFETIME=30
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_FORM=20

# Cache
CACHE_DRIVER=file
CACHE_TTL=3600
