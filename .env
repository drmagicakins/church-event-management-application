# ============================================================================
# Team Praise Official - Environment Configuration
# Copy this file to .env and update the values for your environment.
# ============================================================================

# Application
APP_NAME="Team Praise Official"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://teampraise.org
#APP_KEY=generate-a-64-character-random-key-here # generate key
APP_KEY=base64:your_generated_key_here # Use the command below to generate a key and replace the value above
# Command to generate a key: php artisan key:generate --show

APP_TIMEZONE=Africa/Lagos

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=teampraise_app
DB_USERNAME=your_db_user # Replace with your actual database username
DB_PASSWORD=your_db_password # Replace with your actual database password
DB_CHARSET=utf8mb4 

# Mail (PHPMailer via SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=officialteampraise@gmail.com
MAIL_PASSWORD=your_mail_password # Replace with your actual email password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=officialteampraise@gmail.com
MAIL_FROM_NAME="Team Praise Official"

# Upload settings
UPLOAD_MAX_MB=8
UPLOAD_ALLOWED_EXT=jpg,jpeg,png,webp,gif,mp4,mp3,pdf

# Session
SESSION_LIFETIME=30
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_FORM=20

# Cache
CACHE_DRIVER=file
CACHE_TTL=3600
